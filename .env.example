# MongoDB
MONGODB_URI=mongodb://localhost:27017/integrated-life

# JWT
JWT_SECRET=your-secret-key-min-32-chars

# Google OAuth (from Google Cloud Console)
# Web client: used by server to verify tokens + by Next.js
GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_WEB=your-web-client-secret
# iOS client: server verifies tokens from both Web and iOS
GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com

# API (for CORS and client config)
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Client Web (Next.js - prefix with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com

# Server
MOBILE_BUNDLE_ID=com.integratedlife.app
PORT=3001
NODE_ENV=development

# Cloudflare R2 (recipe images). Public URL is from R2 bucket → Settings → Public Development URL.
# Set this so uploads and the migrate:recipe-r2-urls script use the same host clients can load.
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=integrated-life-images
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Apple Push Notifications (optional — for remote alerts when a health report is ready)
# Create an APNs Auth Key in Apple Developer → Keys; download AuthKey_XXX.p8 (do not commit it).
# Enable Push Notifications for App ID com.integratedlife.app in Identifiers.
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=YOUR10CHARTEAM
# APNS_KEY_PATH=/absolute/path/to/AuthKey_XXXXXX.p8
# Use sandbox for local Xcode installs; production for TestFlight/App Store server:
# APNS_USE_SANDBOX=true
